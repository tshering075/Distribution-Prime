# Required — Supabase project (Settings → API)
# Use the anon/public key (JWT eyJ... or publishable sb_publishable_...).
# No leading spaces on variable names. Cloudflare Pages: add same names under
# Settings → Variables and Secrets → Production, then redeploy.
REACT_APP_SUPABASE_URL=https://your-project.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-anon-key

# Optional — force Supabase-only login in development (default: true in production builds)
# REACT_APP_REQUIRE_SUPABASE_AUTH=true

# Optional — subpath deploy (e.g. Cloudflare Pages project path)
# PUBLIC_URL=
